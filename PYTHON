#!/bin/bash

# =============================================
# ЛАБОРАТОРНАЯ РАБОТА №8 - ВУЗ
# Скрипт для запуска отчётов на Python
# =============================================

show_help() {
    echo "============================================="
    echo "  ЛАБОРАТОРНАЯ РАБОТА №8 - ВУЗ"
    echo "============================================="
    echo ""
    echo "ОПИСАНИЕ КОМАНД:"
    echo "  ./PYTHON task1                                - отчёт по всем группам и дисциплинам"
    echo "  ./PYTHON task1 ИНФ-101                       - отчёт по конкретной группе"
    echo "  ./PYTHON task1 ИНФ-101 Программирование      - отчёт по группе и дисциплине"
    echo "  ./PYTHON task2                               - сводная таблица (группы × дисциплины)"
    echo "  ./PYTHON task2 ИНФ                           - сводная таблица с фильтром"
    echo "  ./PYTHON task3                               - график динамики успеваемости"
    echo "  ./PYTHON task4                               - круговая диаграмма"
    echo "  ./PYTHON task4 ИНФ                           - круговая диаграмма с фильтром"
    echo "  ./PYTHON all                                 - выполнить все задачи"
    echo "  ./PYTHON save                                - сохранить все графики"
    echo "  ./PYTHON save --force                        - сохранить с перезаписью"
    echo ""
    echo "ПРИМЕРЫ:"
    echo "  ./PYTHON task1"
    echo "  ./PYTHON task1 ИНФ-101"
    echo "  ./PYTHON task1 ИНФ-101 Программирование"
    echo "  ./PYTHON task2"
    echo "  ./PYTHON task2 ИНФ"
    echo "  ./PYTHON task3"
    echo "  ./PYTHON task4"
    echo "  ./PYTHON task4 ИНФ"
    echo "  ./PYTHON save --force"
}

case "$1" in
    task1)
        if [ -z "$2" ]; then
            echo " Выполняется отчёт по всем группам..."
            python3 analytics_report.py task1
        elif [ -z "$3" ]; then
            echo " Выполняется отчёт по группе: $2..."
            python3 analytics_report.py task1 "$2"
        else
            echo " Выполняется отчёт по группе: $2, дисциплина: $3..."
            python3 analytics_report.py task1 "$2" "$3"
        fi
        ;;
    task2)
        if [ -z "$2" ]; then
            echo " Выполняется сводная таблица по всем группам..."
            python3 analytics_report.py task2
        else
            echo " Выполняется сводная таблица по группам, содержащим: $2..."
            python3 analytics_report.py task2 "$2"
        fi
        ;;
    task3)
        echo " Построение графика динамики успеваемости..."
        python3 analytics_chart.py task3
        ;;
    task4)
        if [ -z "$2" ]; then
            echo " Построение круговой диаграммы по всем группам..."
            python3 analytics_chart.py task4
        else
            echo " Построение круговой диаграммы для групп, содержащих: $2..."
            python3 analytics_chart.py task4 "$2"
        fi
        ;;
    save)
        if [ "$2" = "--force" ]; then
            echo " Сохранение всех графиков (перезапись)..."
            python3 analytics_chart.py save-all --force
        else
            echo " Сохранение всех графиков..."
            python3 analytics_chart.py save-all
        fi
        ;;
    all)
        echo "============================================="
        echo "  ВЫПОЛНЕНИЕ ВСЕХ ЗАДАЧ"
        echo "============================================="
        echo ""
        echo "--- ЗАДАЧА 1: ОТЧЁТ ---"
        python3 analytics_report.py task1
        echo ""
        echo "--- ЗАДАЧА 2: СВОДНАЯ ТАБЛИЦА ---"
        python3 analytics_report.py task2
        echo ""
        echo "--- ЗАДАЧА 3: ГРАФИК ---"
        python3 analytics_chart.py task3
        echo ""
        echo "--- ЗАДАЧА 4: ДИАГРАММА ---"
        python3 analytics_chart.py task4
        ;;
    *)
        show_help
        ;;
esac
